# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# JWT — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_min_32_chars

# Session — use a different long random string
SESSION_SECRET=your_session_secret_min_32_chars

# Comma-separated list of Google emails that have supervisor access
SUPERVISOR_EMAILS=supervisor1@vitapstudent.ac.in,supervisor2@vitapstudent.ac.in

# App
PORT=5000
NODE_ENV=development
