<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luggage Web Check In Portal | VIT Vellore</title>
</head>
<body>
    <h1>Luggage Web Check-In Portal</h1>
    <form action="/checkin" method="POST">

        <label>Check In Date</label>
        <input type="date" name="check_in_date">
                <label>Check In Date</label>

        <input type="date" name="check_out_date">
                <label>Check In Date</label>

        <input type="time" name="check_in_time">
                <label>Check In Date</label>

        <input type="time" name="check_out_time">
                <label>Check In Date</label>

        <textarea name="luggage_info"></textarea>
                <label>Check In Date</label>

        <input type="file" name="image">
        <input type="submit" value="Schedule Check-In">

    </form>
    
</body>
</html>