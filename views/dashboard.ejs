<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luggage Web Check In Portal | VIT Vellore</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

</head>
<body>
        <%- include('partials/navbar.ejs') %>
        <div class="container">
                <% if(!data && data.length==0) { %>
                
               
                
                                        <div class="card">
  <div class="card-header">
    <b>Schedule Check-In</b>
  </div>
  <div class="card-body">
    <form action="/schedule-check-in" method="POST">
  <div class="mb-3">

        <label class="form-label" >Check In Date</label>
        <input type="date" required min="2026-04-21" class="form-control" name="scheduled_check_in_date">

        </div>    <div class="mb-3">
 <label class="form-label">Check In Time</label>

        <input type="time" required min="10:00" max="17:00" step="60" class="form-control" name="scheduled_check_in_time">
                </div>   <div class="mb-3">
<label class="form-label">Luggage Information</label>

        <textarea class="form-control" name="luggage_info" placeholder="Mention the Luggage Type along with the Quantity. Example: 1 Bucket, 1 Mattress, 2 Carton Box"></textarea>
                 </div>  <div class="mb-3">
<label class="form-label">Image of Luggae</label>

        <input class="form-control" type="file" name="image"></div> 
        <button type="submit" class="btn btn-primary">Schedule Check-In <i class="bi bi-check-circle-fill"></i></button>

    </form>
  </div>
</div>

<hr>

                <% } %>



<h4>My Scheduled Check-In</h4>

<% if(data && data.length>0) { %>

        <table class="table">

        <tr>    
                <th>Scheduled Check-In Date & Time</th>
                <th>Check-In Date & Time</th>
                <th>Received By</th>
                <th>Luggage Information</th>
                <th>Image of Luggage</th>
                <th>Check-Out Date & Time</th>
                <th>Released By</th>
                <th>Action</th>

        </tr>
        

<% data.forEach(function(data){ %>

        <tr>
                <td><%= data.scheduled_check_in_date %> | <%= data.scheduled_check_in_time %></td>

                <% if(data.check_in_date && data.check_in_time) { %>
                                <td><%= data.check_in_date %> | <%= data.check_in_time %></td>

                <% } else { %> 
                        <td><i class="bi bi-slash-circle-fill"></i></td>
                <% } %>


                  <% if(data.received_by ) { %>
                                <td><%= data.received_by %></td>

                <% } else { %> 
                        <td><i class="bi bi-slash-circle-fill"></i></td>
                <% } %>


               
                <td><%= data.luggage_info %></td>
                <td><%= data.image %></td>

                 <% if( data.check_out_date&& data.check_out_time ) { %>
                                <td><%= data.check_out_date %> | <%= data.check_out_time %></td>

                <% } else { %> 
                        <td><i class="bi bi-slash-circle-fill"></i></td>
                <% } %>


                <% if( data.released_by ) { %>
                                <td><%= data.released_by %></td>

                <% } else { %> 
                        <td><i class="bi bi-slash-circle-fill"></i></td>
                <% } %>

              
                <td><a class="btn btn-outline-primary" href="/modify/<%= data.id %>"><i class="bi bi-pencil-square"></i> Modify</a></td>
        </tr>



<% }) %>


<%  } else { %>
        <h6><i class="bi bi-emoji-frown-fill"></i> You have not scheduled your Check-In!</h6>
        <% } %>





</table>
        
   

    </div>
    
</body>

<script src="/script.js"></script>


</html>